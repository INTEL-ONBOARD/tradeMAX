{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist/main",
    "rootDir": "src",
    "module": "CommonJS",
    "moduleResolution": "node",
    "types": ["node"]
  },
  "include": ["src/main/**/*", "src/services/**/*", "src/db/**/*", "src/shared/**/*"],
  "exclude": ["**/__tests__/**", "**/*.test.ts", "src/**/__tests__/**", "src/**/*.test.ts"]
}
