{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist/preload",
    "rootDir": "src",
    "module": "CommonJS",
    "moduleResolution": "node",
    "types": ["node"]
  },
  "include": ["src/preload/**/*", "src/shared/**/*"],
  "exclude": ["**/__tests__/**", "**/*.test.ts", "src/**/__tests__/**", "src/**/*.test.ts"]
}
